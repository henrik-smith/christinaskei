---
const benefits = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>`,
    title: 'Tilpasset ditt nivå',
    description: 'Programmet møter deg der du er — uansett om du er nybegynner eller erfaren.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
    title: 'Styrke + mobilitet',
    description: 'Den brikken de fleste mangler. Bli sterkere og smidigere samtidig.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`,
    title: 'Progressiv oppbygging',
    description: 'Strukturerte programmer som bygger uke for uke — fra 2 til 5 dager.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
    title: 'Fleksibelt i hverdagen',
    description: 'Tren når og hvor det passer deg. Programmet tilpasses dine dager.',
  },
];
---

<section class="section-padding bg-bg-dark">
  <div class="container-content">
    <h2 class="text-3xl md:text-4xl font-bold tracking-heading mb-16 text-text-light text-center">
      Den manglende brikken i treningen din
    </h2>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-10">
      {benefits.map(benefit => (
        <div class="bg-bg-light rounded-card p-10 md:p-12">
          <div class="text-accent mb-5" set:html={benefit.icon} />
          <h3 class="text-xl font-bold tracking-heading mb-3 text-text-primary">
            {benefit.title}
          </h3>
          <p class="text-text-secondary leading-relaxed">
            {benefit.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
