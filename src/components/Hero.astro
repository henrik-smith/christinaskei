<section class="relative min-h-screen flex items-center bg-bg-dark overflow-hidden">
  <!-- Background placeholder — replace with real video/image -->
  <div class="absolute inset-0 bg-gradient-to-br from-bg-dark via-bg-dark/90 to-accent/10"></div>
  <!-- When you have a hero video:
  <video autoplay muted loop playsinline class="absolute inset-0 w-full h-full object-cover opacity-40">
    <source src="/videos/hero.mp4" type="video/mp4" />
  </video>
  -->
  <!-- When you have a hero image: -->
  <!-- <img src="/images/hero.webp" alt="" class="absolute inset-0 w-full h-full object-cover opacity-40" /> -->
  <div class="absolute inset-0 bg-bg-dark/60"></div>

  <div class="container-content relative z-10 pt-28 pb-20 md:pt-36 md:pb-28">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text-light tracking-heading leading-[1.1] mb-6">
        Finn flyten din.<br />Bli sterkere.<br />
        <span class="text-accent">Fra hvor som helst.</span>
      </h1>

      <p class="text-lg md:text-xl text-text-light/80 max-w-xl mb-10 leading-relaxed">
        Live yoga online og personlig coaching — tilpasset deg og din hverdag.
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a href="#program" class="btn-primary text-center">
          Se gruppetimer
        </a>
        <a href="#kontakt" class="btn-ghost text-center">
          Book en gratis samtale
        </a>
      </div>
    </div>
  </div>

  <!-- Trust strip -->
  <div class="absolute bottom-0 left-0 right-0 border-t border-white/10 bg-bg-dark/80 backdrop-blur-sm">
    <div class="container-content py-4 flex flex-wrap justify-center gap-x-8 gap-y-2 text-sm text-text-light/60">
      <span>Sertifisert i Hatha & Vinyasa</span>
      <span class="hidden sm:inline text-text-light/20">|</span>
      <span>Tidligere turner</span>
      <span class="hidden sm:inline text-text-light/20">|</span>
      <span>PT ved Studio Jobbsprek, Aker Brygge</span>
    </div>
  </div>
</section>
