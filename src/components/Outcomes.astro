---
const outcomes = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
    title: 'Mer energi i hverdagen',
    description: 'Tren smart, ikke bare hardt. Få overskudd som varer hele dagen.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    title: 'Mindre smerter og stivhet',
    description: 'Si ha det til vond rygg, stive hofter og spenninger fra kontordagen.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
    title: 'Sterkere kropp',
    description: 'Bygg funksjonell styrke som gjør hverdagen lettere — fra å løfte barn til å bære handleposer.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Bedre søvn og restitusjon',
    description: 'En kropp i balanse sover bedre. Mobilitet og styrke gir dypere hvile.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>`,
    title: 'Bedre bevegelighet',
    description: 'Få tilbake bevegelsesfrihet du har mistet. Beveg deg uten begrensninger.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Rutine som faktisk varer',
    description: 'Et program tilpasset din timeplan betyr at du faktisk holder det oppe — uke etter uke.',
  },
];
---

<section class="section-padding bg-bg-light">
  <div class="container-content">
    <h2 class="text-3xl md:text-4xl font-bold tracking-heading mb-4 text-text-primary text-center">
      Hva du kan forvente
    </h2>
    <p class="text-text-secondary text-center mb-16 max-w-lg mx-auto">
      Konkrete resultater fra et program bygget på styrke, mobilitet og personlig oppfølging.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-10">
      {outcomes.map(outcome => (
        <div class="flex gap-5">
          <div class="text-accent flex-shrink-0 mt-1" set:html={outcome.icon} />
          <div>
            <h3 class="font-bold text-text-primary mb-1.5">{outcome.title}</h3>
            <p class="text-text-secondary text-[15px] leading-relaxed">{outcome.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
